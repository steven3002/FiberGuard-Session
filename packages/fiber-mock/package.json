{
  "name": "@fiberguard/fiber-mock",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone mock Fiber Network node speaking the JSON-RPC 2.0 subset FiberGuard forwards to (dev/demo upstream)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fiber-mock": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/cli.js start",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
