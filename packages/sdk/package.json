{
  "name": "@fiberguard/session",
  "version": "0.1.0",
  "private": true,
  "description": "Typed, isomorphic client for the FiberGuard Session gateway: scoped, revocable, spend-limited Fiber payment sessions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fiberguard/shared": "workspace:*"
  },
  "devDependencies": {
    "@fiberguard/fiber-mock": "workspace:*",
    "@fiberguard/gateway": "workspace:*",
    "@fiberguard/policy": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
